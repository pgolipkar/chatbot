# Copy this file to .env and fill in your real values.

# Server
PORT=8000
NODE_ENV=development
DB_PATH=./db/helpdesk.db

# Claude / Anthropic
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
CLAUDE_MODEL=claude-sonnet-4-20250514

# Microsoft Bot Framework / Teams
# Get these after creating an Azure Bot resource.
MicrosoftAppId=YOUR_AZURE_BOT_APP_ID
MicrosoftAppPassword=YOUR_AZURE_BOT_CLIENT_SECRET

# Email OTP
# For quick local testing, you can leave EMAIL_USER and EMAIL_PASS empty.
# The OTP will be printed in server.log instead of being emailed.
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=IT Helpdesk Bot <no-reply@yourcompany.com>
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
# Local testing only. Remove or blank this in production.
DEFAULT_OTP_CODE=123456
MAX_OTP_ATTEMPTS=3
MAX_USER_LOOKUP_ATTEMPTS=2

# Service Desk / Ticket Assignment
DEFAULT_SD_ASSIGNMENT=SD Team
SD_TEAM_EMAIL=servicedesk@yourcompany.com

# Optional Teams channel webhook for SD ticket notifications.
# If empty, tickets are still created in local SQLite and dashboard.
SD_TEAM_WEBHOOK_URL=

# Company Display
COMPANY_NAME=Your Company Name
